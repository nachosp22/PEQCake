APP_NAME=peq-public
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=peqcake
DB_USERNAME=root
DB_PASSWORD=
# SQLite fallback (for quick local-only testing):
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

SESSION_DRIVER=database
SESSION_COOKIE=peq_public_session
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Comma-separated list of admin user emails allowed in production.
ADMIN_ALLOWED_EMAILS=

# Public storefront route (without leading slash). Example: tienda
STORE_PATH=tienda

# Private admin route segment (without leading slash).
# Use a hard-to-guess value in production, e.g. panel-4f9e2c6d8b1a73a5
ADMIN_PATH=panel-62f0f6d8c9b14e71a3

# Optional legacy admin route for backward compatibility redirects.
LEGACY_ADMIN_PATH=peqcakes-panel-seguro-2026

# Absolute admin app URL used by public-host legacy admin redirects.
# Example: https://admin.peqcakes.com
ADMIN_APP_URL=

# setup.sh optional admin bootstrap vars
SETUP_ADMIN_EMAIL=
SETUP_ADMIN_NAME=
SETUP_ADMIN_PASSWORD=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_BCC_ADDRESS=
MAIL_BCC_NAME=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PEQ_PUBLIC_HERO_VIDEO_ENABLED=true
PEQ_PUBLIC_HERO_VIDEO_MOBILE_AUTOPLAY=false
PEQ_GA4_MEASUREMENT_ID=
